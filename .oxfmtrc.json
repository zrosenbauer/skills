{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "experimentalSortImports": {},
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    ".turbo",
    ".kidd",
    "*-workspace",
    "coverage",
    "**/*.d.ts",
    "pnpm-lock.yaml"
  ]
}
