{
  "name": "@zrosenbauer/skill-tools",
  "version": "0.0.0",
  "private": true,
  "description": "CLI + TUI for authoring, linting, and evaluating skills in this monorepo",
  "license": "MIT",
  "author": "Zac Rosenbauer <zacrosenbauer@gmail.com>",
  "bin": {
    "skill-tools": "./dist/index.mjs"
  },
  "type": "module",
  "scripts": {
    "dev": "kidd dev",
    "build": "kidd build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .kidd coverage"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "@kidd-cli/core": "^0.23.1",
    "es-toolkit": "^1.45.0",
    "ink": "^7.0.2",
    "react": "^19.2.6",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@kidd-cli/cli": "^0.11.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.5"
  }
}
